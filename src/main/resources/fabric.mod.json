{
	"schemaVersion": 1,
	"id": "rpg-camera-and-controls",
	"version": "${version}",
	"name": "RPG Camera and Controls",
	"description": "Adds an RPG-style third-person camera to Minecraft.",
	"authors": [
		"Nikolas Beckel (Kunga)"
	],
	"contact": {
		"homepage": "https://github.com/nikolas-beckel/rpg-camera-and-controls",
		"sources": "https://github.com/nikolas-beckel/rpg-camera-and-controls"
	},
	"license": "MIT",
	"icon": "assets/rpg-camera-and-controls/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"kunga.rpgcameraandcontrols.RpgCameraAndControls"
		],
		"client": [
			"kunga.rpgcameraandcontrols.RpgCameraAndControlsClient"
		]
	},
	"mixins": [
      "rpg-camera-and-controls.mixins.json",
		{
			"config": "rpg-camera-and-controls.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": "~1.21.9",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}